PLEX_URL=http://host:32400
PLEX_TOKEN=your_plex_token

# Comma-separated partial names. Example simulcast:
# PLEX_CLIENTS=Living Room,Bedroom
PLEX_CLIENTS=Living Room

PLEX_LIBRARY=TV Shows
PLEX_COLLECTION=Star Trek TV Collection

# Optional: set false to use legacy single-episode queue behavior.
PLEX_SHUFFLE_CONTINUOUS=true

# Optional: webhook mode for Home Assistant REST trigger
# npm run webhook
# PLEX_WEBHOOK_HOST=0.0.0.0
# PLEX_WEBHOOK_PORT=8787
# PLEX_WEBHOOK_TOKEN=change_me
